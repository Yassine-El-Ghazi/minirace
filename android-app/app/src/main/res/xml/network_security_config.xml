<?xml version="1.0" encoding="utf-8"?>
<!-- Dev-only: allows plain HTTP to the local MineRace server.
     Replace with HTTPS + proper cert pinning before any production use. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
